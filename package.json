{
  "name": "@dbvex/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Vue 3 UI component library — TypeScript strict, design tokens, a11y",
  "author": "dbvex",
  "license": "MIT",
  "keywords": [
    "vue3",
    "components",
    "typescript",
    "design-system",
    "ui-library"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dbvex/ui"
  },
  "homepage": "https://dbvex.github.io/ui/",
  "files": [
    "dist"
  ],
  "main": "./dist/ui.umd.js",
  "module": "./dist/ui.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/ui.es.js",
      "require": "./dist/ui.umd.js"
    },
    "./button": {
      "types": "./dist/types/components/button/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./input": {
      "types": "./dist/types/components/input/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./select": {
      "types": "./dist/types/components/select/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./checkbox": {
      "types": "./dist/types/components/checkbox/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./label": {
      "types": "./dist/types/components/label/index.d.ts",
      "import": "./dist/ui.es.js"
    },
    "./styles": {
      "import": "./dist/ui.css"
    }
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "type-check": "vue-tsc --noEmit",
    "build": "vite build",
    "test:unit": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "vue-demi": "^0.14.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "ajv": "^8.18.0",
    "jsdom": "^29.0.0",
    "less": "^4.1.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.5"
  },
  "peerDependencies": {
    "vue": ">=3.2.47"
  }
}
